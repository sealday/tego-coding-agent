{
  "name": "tego-coding-agent",
  "version": "0.1.0",
  "type": "module",
  "description": "A Bun-based autonomous coding harness built on the latest PI Coding Agent SDK.",
  "bin": {
    "tego-coding-agent": "./src/index.ts",
    "autorun-harness": "./src/index.ts"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --packages external",
    "dev": "bun run ./src/index.ts",
    "start": "bun run ./src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.77.0",
    "@earendil-works/pi-coding-agent": "^0.77.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "ora": "^9.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.4",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
